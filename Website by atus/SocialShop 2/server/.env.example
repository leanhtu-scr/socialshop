# Copy file này thành .env và điền giá trị thật của bạn.
# KHÔNG commit file .env (chứa thông tin nhạy cảm) lên Git.

PORT=5000

# MongoDB Atlas connection string (tạo free cluster tại mongodb.com/atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/socialshop

# Chuỗi bí mật để ký JWT — đổi thành chuỗi ngẫu nhiên dài, khó đoán
JWT_SECRET=doi_chuoi_nay_thanh_bi_mat_cua_ban
JWT_EXPIRES_IN=7d
