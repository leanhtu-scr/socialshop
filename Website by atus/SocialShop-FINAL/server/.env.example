# ══════════════════════════════════════════
# SocialShop — Environment Variables
# Copy file này thành .env và điền thông tin
# ══════════════════════════════════════════

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5000

# MongoDB Atlas (free tier: cloud.mongodb.com)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/socialshop

# JWT
JWT_SECRET=socialshop_super_secret_key_change_this_2026
JWT_EXPIRE=7d

# Cloudinary (tùy chọn, để upload ảnh lên cloud)
# Lấy tại: cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VNPay sandbox (tùy chọn)
VNPAY_TMN_CODE=
VNPAY_SECURE_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/pages/payment-result.html

# MoMo sandbox (tùy chọn)
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
